{
  "core_config": {
    "spec_name": "example_spec",
    "spec_alias": "Example Spec",
    "description": "Example governed ingestion spec.",
    "owner_role": "app_admin",
    "is_published": false,
    "is_archived": false,
    "is_multi_role": false
  },
  "column_config": [
    {
      "name": "record_id",
      "type": "string",
      "description": "Stable source record identifier.",
      "tests": ["not_null"]
    },
    {
      "name": "record_date",
      "type": "date",
      "description": "Business date for the record.",
      "format": "%Y-%m-%d",
      "tests": ["not_null"]
    },
    {
      "name": "amount",
      "type": "number",
      "description": "Example amount.",
      "tests": []
    }
  ],
  "file_rules": {
    "file_format": {
      "file_type": "csv",
      "record_delimiter": "\n",
      "field_delimiter": ",",
      "field_optionally_enclosed_by": "\"",
      "escape_unenclosed_field": "\\",
      "encoding": "UTF8",
      "parse_header": true,
      "save_header": true
    }
  },
  "attachment_policy": {
    "attachments_enabled": false,
    "attachment_required": false
  }
}
